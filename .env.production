# Frontend Environment Variables (Production)
# Set VITE_API_URL to your deployed backend URL on Vercel.
#
# If frontend and backend are deployed to the SAME Vercel project, leave empty:
# VITE_API_URL=
#
# If backend is a SEPARATE Vercel project, set it to that project's URL:
# VITE_API_URL=https://shikshavision-api.vercel.app
VITE_API_URL=
